---
import Base from '../layouts/Base.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { site } from '../config/site';

const featuredEntries = [
  {
    no: 'I',
    tag: 'Practice Management',
    title: 'Boulevard 2026 — Practice Review',
    excerpt: 'Boulevard sits at the high end of the medspa software market. Our team operates it across multi-location practices — and explains where the premium pays back.',
    href: '/reviews/boulevard-review-2026',
    readTime: '13 min',
  },
  {
    no: 'II',
    tag: 'Practice Management',
    title: 'Zenoti for Aesthetic Practices',
    excerpt: 'Zenoti is the enterprise alternative. The membership engine and reporting depth are exceptional; the trade-off is implementation weight measured in weeks, not days.',
    href: '/reviews/zenoti-review-2026',
    readTime: '12 min',
  },
  {
    no: 'III',
    tag: 'Guide',
    title: 'The Medspa Tech Stack',
    excerpt: 'Six layers — PMS, marketing, reputation, payments, retention, telehealth — and the specific platforms our team specifies for practices growing from one location to five.',
    href: '/guides/best-medspa-tech-stack-2026',
    readTime: '14 min',
  },
];

const editorialNotes = [
  {
    glyph: 'I',
    title: 'Clinical practitioners',
    body: 'Every review comes from operators who have actually deployed the platform across treatment rooms, providers, and front-desk teams — not from demo screenshots.',
  },
  {
    glyph: 'II',
    title: 'Premium service economics',
    body: 'Aesthetic practices price differently than salons. We test for the workflows that protect margin: memberships, package deferral, provider compensation, retail attach.',
  },
  {
    glyph: 'III',
    title: 'Transparent specification',
    body: 'List pricing, implementation cost, processing markup, integration fees. The notes are written for an operator deciding — not a vendor closing.',
  },
];
---
<Base title={site.name} description={site.description}>

  <!-- HERO — editorial cover -->
  <section class="hero">
    <div class="hero-grid-overlay"></div>
    <div class="hero-inner container">
      <div class="hero-content">
        <div class="hero-badge" style="font-family:'Playfair Display',serif; font-style:italic; letter-spacing:0.03em;">
          Written by aesthetic practice operators
        </div>
        <h1>The journal of software <em>that runs the aesthetic practice</em></h1>
        <p class="hero-sub">
          Independent reviews of practice management, marketing, and member-experience platforms —
          written by operators who manage providers, retention, and clinical workflow.
        </p>
        <div class="hero-actions">
          <a href="/reviews" class="btn btn-teal btn-lg">Read the Reviews →</a>
          <a href="/guides/best-medspa-tech-stack-2026" class="btn btn-outline btn-lg" style="color:#FFFFFF; border-color:rgba(255,255,255,.6); background:rgba(255,255,255,.08);">The Tech Stack</a>
        </div>
      </div>

      <div class="hero-stat-card">
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">8<em>+</em></span>
            <span class="stat-label">Platforms reviewed</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">Aesthetic</span>
            <span class="stat-label">Practice focus</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">Independent</span>
            <span class="stat-label">Editorial standard</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">2026</span>
            <span class="stat-label">Journal edition</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED ENTRIES -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="section-label">Featured Entries</p>
        <h2 class="section-title">This edition's selected reviews</h2>
        <p class="section-sub" style="font-family:'Playfair Display',Georgia,serif; font-style:italic; opacity:0.78; max-width:42rem; margin-top:0.75rem;">
          Three platforms reviewed in depth — tested against the workflow realities of multi-provider aesthetic practices.
        </p>
      </div>

      <div class="card-grid">
        {featuredEntries.map(entry => (
          <a href={entry.href} class="post-card">
            <div class="post-card-body">
              <div style="display:flex; align-items:baseline; gap:0.85rem; margin-bottom:0.6rem;">
                <span style="font-family:'Playfair Display',serif; font-style:italic; color:#d28caa; font-size:0.92rem; letter-spacing:0.06em;">Entry {entry.no}</span>
                <span class="post-card-tag">{entry.tag}</span>
              </div>
              <h3 style="font-family:'Playfair Display',Georgia,serif;">{entry.title}</h3>
              <p>{entry.excerpt}</p>
              <div class="post-card-meta">
                <span style="font-style:italic;">Reading time</span>
                <span>·</span>
                <span>{entry.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/reviews" class="btn btn-outline">All Entries →</a>
      </div>
    </div>
  </section>

  <!-- EDITORIAL NOTES -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <p class="section-label">Editorial Notes</p>
        <h2 class="section-title">How {site.name} is written</h2>
      </div>

      <div class="feature-grid">
        {editorialNotes.map(note => (
          <div class="feature-item">
            <div style="font-family:'Playfair Display',serif; font-style:italic; color:#d28caa; font-size:1.5rem; letter-spacing:0.04em; margin-bottom:0.6rem;">{note.glyph}.</div>
            <h3 style="font-family:'Playfair Display',Georgia,serif;">{note.title}</h3>
            <p>{note.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="container" style="padding:clamp(1.5rem,4vw,2rem) clamp(1rem,4vw,1.5rem) clamp(2.5rem,6vw,4rem);">
    <NewsletterSignup
      variant="hero"
      title={`The ${site.name} journal, by email`}
      description="One weekly entry — new reviews and field notes from the practice floor. No spam."
      ctaLabel="Subscribe"
    />
  </section>

</Base>
