{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "astro",
  "redirects": [
    {
      "source": "/recommends/gohighlevel",
      "destination": "https://www.gohighlevel.com/?fp_ref=stosh61",
      "permanent": false
    },
    {
      "source": "/recommends/birdeye",
      "destination": "https://birdeye.com/",
      "permanent": false
    },
    {
      "source": "/recommends/vagaro",
      "destination": "https://www.vagaro.com/",
      "permanent": false
    },
    {
      "source": "/recommends/pabau",
      "destination": "https://pabau.com/",
      "permanent": false
    },
    {
      "source": "/recommends/podium",
      "destination": "https://www.podium.com/",
      "permanent": false
    },
    {
      "source": "/recommends/mailchimp",
      "destination": "https://mailchimp.com/",
      "permanent": false
    },
    {
      "source": "/recommends/boulevard",
      "destination": "https://www.joinblvd.com/",
      "permanent": false
    },
    {
      "source": "/recommends/zenoti",
      "destination": "https://www.zenoti.com/",
      "permanent": false
    },
    {
      "source": "/recommends/aesthetic-record",
      "destination": "https://www.aestheticrecord.com/",
      "permanent": false
    },
    {
      "source": "/recommends/symplast",
      "destination": "https://www.symplast.com/",
      "permanent": false
    },
    {
      "source": "/recommends/cherry",
      "destination": "https://withcherry.com/",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 2"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 3"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 4"
    },
    {
      "path": "/api/refill-queue",
      "schedule": "0 13 * * 0"
    }
  ]
}
